# 複製此檔為 .env，在 docker compose up 前填入你的值
# .env 已被 .gitignore 排除，不會進版控

# --- MySQL ---
# root 帳號的密碼（同時是後端連 DB 用的密碼）
MYSQL_ROOT_PASSWORD=root

# --- 後端 JWT ---
# 至少 32 bytes（HS256 要求），請用密碼產生器生
# 例： openssl rand -base64 48
JWT_SECRET=please-change-this-to-a-strong-random-secret-at-least-32-bytes

# --- Google OAuth（選用，未設定時 Google 登入按鈕會隱藏） ---
# 到 https://console.cloud.google.com/apis/credentials 建立「OAuth 用戶端 ID」
# 同一個 client-id 要分別灌進前端與後端
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
